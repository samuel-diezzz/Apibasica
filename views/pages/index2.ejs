<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head'); %>
</head>
<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="jumbotron">
            <h1>¡Hola! Bienvenido a la tienda</h1>
            <p class="lead">Aquí tienes la lista de productos disponibles traídos desde la API:</p>
            
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-hover bg-white">
                    <thead class="thead-dark">
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Imagen</th>
                            <th scope="col">Producto</th>
                            <th scope="col">Categoría</th>
                            <th scope="col">Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% productos.forEach(function(producto) { %>
                            <tr>
                                <td><%= producto.id %></td>
                                <td>
                                    <img src="<%= producto.image %>" alt="<%= producto.title %>" style="max-width: 50px; height: auto;">
                                </td>
                                <td><strong><%= producto.title %></strong></td>
                                <td><span class="badge badge-secondary"><%= producto.category %></span></td>
                                <td><strong>$<%= producto.price %></strong></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>
</html>